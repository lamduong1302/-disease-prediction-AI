# Environment Configuration Example
# 
# Copy this file to .env and fill in your actual values
# Then the app can read these variables:
#   - On Windows: set variables before running
#   - On Linux/Mac: source this file or export variables

# ============================================
# GEMINI AI Configuration (Optional but Recommended)
# ============================================

# Your Google Gemini API key
# Get it for free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-api-key-here

# The model to use
# Options: gemini-1.5-flash (recommended), gemini-1.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash

# Enable/disable Gemini integration (1=enabled, 0=disabled)
GEMINI_ENABLED=1

# ============================================
# Flask Configuration
# ============================================

# Secret key for session management (change this in production!)
FLASK_SECRET_KEY=your-secret-key-here-change-in-production

# ============================================
# Database Configuration (PostgreSQL)
# ============================================

# Example:
# POSTGRES_DSN=postgresql://user:password@localhost:5432/disease_prediction_app
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/disease_prediction_app

# ============================================
# ML Model Configuration
# ============================================

# Directory containing trained models
MODEL_DIR=models

# ============================================
# Admin User (Optional)
# ============================================

# If set, automatically creates an admin user on first run
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ============================================
# SETUP INSTRUCTIONS
# ============================================
#
# 1. Copy this file and create .env in the project root
# 2. Fill in your GEMINI_API_KEY with your actual key
# 3. On Windows Command Prompt, run:
#    for /f "tokens=1,2 delims==" %a in (.env) do set %a=%b
#
# 4. On Windows PowerShell, run:
#    Get-Content .env | ForEach-Object {
#        $parts = $_ -split '=', 2
#        [Environment]::SetEnvironmentVariable($parts[0], $parts[1])
#    }
#
# 5. On Linux/Mac, run:
#    export $(cat .env | xargs)
#
# 6. Then run the app:
#    python app.py
